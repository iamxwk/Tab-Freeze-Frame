{
  "manifest_version": 3,
  "name": "__MSG_extension_name__",
  "default_locale": "en",
  "version": "1.0.61",
  "description": "__MSG_extension_description__",
  "icons": {
    "16": "16.png",
    "32": "32.png",
    "48": "48.png",
    "128": "icon.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "16.png",
      "32": "32.png"
    }
  },
  "options_page": "options.html"
}
